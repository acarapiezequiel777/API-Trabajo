<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<link rel="stylesheet" href="estilopoke.css">
<title>POKEDEX</title>

</head>

<body>
<h1>Pokedex </h1>
<p id="nombre">
Cargando..</p>
<img id="imagen">
<button id="anterior">Anterior</button>
<button id="siguiente">Siguiente </button>
<p>Número : <span id="numero"></span></p>
<input id="buscar" placeholder="numero o nombre">
<button id="btnBuscar">Buscar</button>
<script>

let numeroPokemon = 1;
const URL ='https://pokeapi.co/api/v2/pokemon/';

async function buscarPokemon(pokemon){

let respuesta = await fetch(URL + pokemon);
let datos = await respuesta.json();
document.getElementById("nombre").textContent = datos.name;
document.getElementById("imagen").src =
datos.sprites.front_default;
document.getElementById("numero").textContent = datos.id;
numeroPokemon = datos.id;
}

buscarPokemon(1);
document.getElementById("btnBuscar").onclick =
function(){
let pokemon = document.getElementById("buscar").value.toLowerCase();
buscarPokemon(pokemon);
}
document.getElementById("siguiente").onclick =
function(){
numeroPokemon++;
buscarPokemon(numeroPokemon);
}

document.getElementById("anterior").onclick =
function(){
if(numeroPokemon > 1){
numeroPokemon--;
buscarPokemon(numeroPokemon);
}
}
</script>
</body>
</html>
